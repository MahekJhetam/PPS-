#include <stdio.h>
#include <math.h>

int main() {
    float angle, radian;

    printf("Enter angle in degrees: ");
    scanf("%f", &angle);

    radian = angle * 3.14159 / 180;

    printf("Sin(%.2f) = %.4f\n", angle, sin(radian));
    printf("Cos(%.2f) = %.4f\n", angle, cos(radian));

    return 0;
}
